<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/welcomeFragment">

    <!-- Auth Flow -->
    <fragment
        android:id="@+id/welcomeFragment"
        android:name="com.example.project.ui.auth.WelcomeFragment"
        android:label="Welcome"
        tools:layout="@layout/fragment_welcome">
        <action
            android:id="@+id/action_welcome_to_login"
            app:destination="@id/loginFragment" />
        <action
            android:id="@+id/action_welcome_to_main"
            app:destination="@id/mainFragment"
            app:popUpTo="@id/welcomeFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.project.ui.auth.LoginFragment"
        android:label="Login"
        tools:layout="@layout/fragment_login">
        <action
            android:id="@+id/action_login_to_register"
            app:destination="@id/registerFragment" />
        <action
            android:id="@+id/action_login_to_onboarding"
            app:destination="@id/deviceScanFragment"
            app:popUpTo="@id/welcomeFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/registerFragment"
        android:name="com.example.project.ui.auth.RegisterFragment"
        android:label="Register"
        tools:layout="@layout/fragment_register">
        <action
            android:id="@+id/action_register_to_login"
            app:destination="@id/loginFragment" />
        <action
            android:id="@+id/action_register_to_onboarding"
            app:destination="@id/deviceScanFragment"
            app:popUpTo="@id/welcomeFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <!-- Onboarding Flow -->
    <fragment
        android:id="@+id/deviceScanFragment"
        android:name="com.example.project.ui.onboarding.DeviceScanFragment"
        android:label="Scan Device"
        tools:layout="@layout/fragment_device_scan">
        <action
            android:id="@+id/action_deviceScan_to_wifiSetup"
            app:destination="@id/wifiSetupFragment" />
    </fragment>

    <fragment
        android:id="@+id/wifiSetupFragment"
        android:name="com.example.project.ui.onboarding.WifiSetupFragment"
        android:label="Wi-Fi Setup"
        tools:layout="@layout/fragment_wifi_setup">
        <action
            android:id="@+id/action_wifiSetup_to_connection"
            app:destination="@id/connectionFragment" />
    </fragment>

    <fragment
        android:id="@+id/connectionFragment"
        android:name="com.example.project.ui.onboarding.ConnectionFragment"
        android:label="Connection"
        tools:layout="@layout/fragment_connection">
        <action
            android:id="@+id/action_connection_to_main"
            app:destination="@id/mainFragment"
            app:popUpTo="@id/welcomeFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <!-- Main Flow (BottomNavigation) -->
    <fragment
        android:id="@+id/mainFragment"
        android:name="com.example.project.ui.main.MainFragment"
        android:label="Main"
        tools:layout="@layout/fragment_main">

        <action
            android:id="@+id/action_main_to_zoneEditor"
            app:destination="@id/zoneEditorFragment" />
        <action
            android:id="@+id/action_main_to_addFriend"
            app:destination="@id/addFriendFragment" />
        <action
            android:id="@+id/action_main_to_settings"
            app:destination="@id/settingsFragment" />
        <action
            android:id="@+id/action_main_to_welcome"
            app:destination="@id/welcomeFragment"
            app:popUpTo="@id/welcomeFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <!-- Zone Editor (Map-based) -->
    <fragment
        android:id="@+id/zoneEditorFragment"
        android:name="com.example.project.ui.zones.MapZoneEditorFragment"
        android:label="Zone Editor"
        tools:layout="@layout/fragment_map_zone_editor">
        <action
            android:id="@+id/action_zoneEditor_to_main"
            app:destination="@id/mainFragment"
            app:popUpTo="@id/mainFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <!-- Add Friend -->
    <fragment
        android:id="@+id/addFriendFragment"
        android:name="com.example.project.ui.social.AddFriendFragment"
        android:label="Add Friend"
        tools:layout="@layout/fragment_add_friend" />

    <!-- Settings -->
    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.example.project.ui.settings.SettingsFragment"
        android:label="Settings"
        tools:layout="@layout/fragment_settings" />

</navigation>
